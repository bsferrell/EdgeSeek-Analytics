# Local .terraform directories (Where the massive provider binaries live)
**/.terraform/*

# .tfstate files (Contains your real infrastructure state and secrets—never commit this!)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (Where you might put local secrets)
*.tfvars
*.tfvars.json
.terraform.tfvars.lock.hcl

# Override files
override.tf
override.tf.json
_override.tf
_override.tf.json